# =============================================
# 🔐 环境变量配置模板
# =============================================
# 复制此文件为 .env 并填入您的实际值
# 注意: .env 文件不会被提交到 Git

# --- JWT 认证 ---
JWT_SECRET_KEY=your_jwt_secret_key_here

# --- TT API (图像生成) ---
TT_API_KEY=your_tt_api_key_here

# --- 阿里云 OSS ---
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=your_bucket_name

# --- 阿里云短信服务 ---
ALIYUN_SMS_ACCESS_KEY_ID=your_sms_access_key_id
ALIYUN_SMS_ACCESS_KEY_SECRET=your_sms_access_key_secret
ALIYUN_SMS_SIGN_NAME=your_sms_sign_name
ALIYUN_SMS_TEMPLATE_CODE=your_sms_template_code
